#UI elements
MDScreen:
    md_bg_color: self.theme_cls.backgroundColor
    MDFloatLayout:
        size: root.width, root.height
        TimePicker
        DatePicker

<TimePicker>:
    MDButton:
        pos_hint: {"center_x": .5, "center_y": .5}
        id: add_deadline
        style: "elevated"
        on_release: self.parent.show_time_picker(0,0)
        #on_cancel: self.dismiss()
       

        MDButtonIcon:
            icon: "plus"

        MDButtonText:
            text: "Add deadline..."

<DatePicker>:
    pos_hint: {'center_x': .5, 'center_y': 1}
    size_hint_x: .5
    MDTextField:
        id: field
        mode: "outlined"
        
        on_focus: self.parent.show_date_picker(self.focus, mydate)

        MDTextFieldHintText:
            id:mydate
            #text: self.set_text_full_date()

        MDTextFieldHelperText:
            text: "MM/DD/YYYY"
            mode: "persistent"

        MDTextFieldTrailingIcon:
            icon: "calendar"
<LabelSlider>:
    MDBoxLayout:
        orientation: 'horizontal'
        MDSlider:
            id: slider    
            step:1
            value:5
            max:10
            min:0
            MDSliderHandle
        MDLabel:
            text: f"{int(slider.value)}/10"

    

