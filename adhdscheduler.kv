            #tags
            MDLabel:
                text: 'Tags (seperate tags by comma):'
                size_hint_y: None
                height: 50
            MDTextField:
                id: tags
                size_hint_y: None
                height: 50


            #Energy
            MDLabel:
                text: "Energy:"
                size_hint_y: None
                multiline: True
                height: 50
            MDTextField:
                id: energy
                size_hint_y: None
                height: 50


            MDLabel:
                text: 'Difficulty:'
                size_hint_y: None
                height: 50
            MDTextField:
                id: difficulty
                size_hint_y: None
                height: 50


            MDLabel:
                text: 'Importance:'
                size_hint_y: None
                height: 50
            MDTextField:
                id: importance
                size_hint_y: None
                height: 50


            MDLabel:
