<AddTask>:
    #Text
    name: name
    description: description
    MDScrollView:
        do_scroll_x: False
        do_scroll_y: True
        size: root.width * 0.6, root.height * 0.8
        bar_margin: 5
        bar_width: 10
        
        name: name
        description: description


        category_name: category_name
        category_priority: category_priority
        category_ID: category_ID


        tags: tags
        energy: energy
        difficulty: difficulty
        importance: importance
        complete: complete


        deadline_date: deadline_date
        deadline_time: deadline_time




        MDBoxLayout:
            id: main_scroll
            orientation: 'vertical'
            
            spacing: 10
            padding: 20
            size_hint_y: None
            height: 2100


            MDLabel:
                text: "Add Task"
                size_hint_y: None
                height: 50




            #name
            MDLabel:
                text: 'Name:'
                size_hint_y: None
                height: 50
            MDTextField:
                id: name
                size_hint_y: None
                height: 50




            #Description
            MDLabel:
                text: "Description:"
                size_hint_y: None
                height: 50
            MDTextField:
                id: description
                multiline: True
                size_hint_y: None
                height: 50




            #should probably be a dropdown list of specific categories that we have
            MDLabel:
                text: 'Category:'
                size_hint_y: None
                height: 50




            MDLabel:
                text: 'Category Name:'
                size_hint_y: None
                height: 50
            MDTextField:
                id: category_name
                size_hint_y: None
                height: 50




            MDLabel:
                text: 'Category Priority:'
                size_hint_y: None
                height: 50
            LabelSlider:
                id: category_priority
                size_hint_y: None
                height: 50




            MDLabel:
                text: 'Category ID:'
                size_hint_y: None
                height: 50
            MDTextField:
                id: category_ID
                size_hint_y: None
                height: 50




            #tags
            MDLabel:
                text: 'Tags (seperate tags by comma):'
                size_hint_y: None
                height: 50
            MDTextField:
                id: tags
                size_hint_y: None
                height: 50




            #Energy
            MDLabel:
                text: "Energy:"
                size_hint_y: None
                multiline: True
                height: 50
            LabelSlider:
                id: energy
                size_hint_y: None
                height: 50




            MDLabel:
                text: 'Difficulty:'
                size_hint_y: None
                height: 50
            LabelSlider:
                id: difficulty
                size_hint_y: None
                height: 50




            MDLabel:
                text: 'Importance:'
                size_hint_y: None
                height: 50
            LabelSlider:
                id: importance
                size_hint_y: None
                height: 50




            MDLabel:
                text: 'Complete:'
                size_hint_y: None
                height: 50
            CheckBox:
                id: complete
                size_hint_y: None
                height: 50




            #Time stuff
            MDLabel:
                text: 'Deadline:'
                size_hint_y: None
                height: 50
            DatePicker:
                id: deadline_date
                size_hint_y: None
                height: 150
            TimePicker:
                id: deadline_time
                size_hint_y: None
                height: 150






            MDLabel:
                text: 'Time it takes to complete:'
                size_hint_y: None
                height: 50
            TimePicker:
                id: time_to_complete
                size_hint_y: None
                height: 150



            MDButton:
                style: 'elevated'
                pos_hint: {"center_x": 0.8, "center_y": 1}
                on_release: root.submit()


                MDButtonText:
                    text: "Add"
                MDButtonIcon:
                    icon: "plus"


