<TimePicker>:
    MDButton:
        id: add_deadline
        style: "elevated"
        on_release: self.parent.show_time_picker(0,0)
        #on_cancel: self.dismiss()
        
        MDButtonIcon:
            icon: "plus"


        MDButtonText:
            text: "Add deadline..."
            halign: "center"


<DatePicker>:
    #pos_hint: {'center_x': .5, 'center_y': 1}
    #size_hint_x: .5
    MDTextField:
        id: field
        mode: "outlined"
        
        on_focus: self.parent.show_date_picker(self.focus, mydate)


        MDTextFieldHintText:
            id:mydate
            #text: self.set_text_full_date()


        MDTextFieldHelperText:
            text: "MM/DD/YYYY"
            mode: "persistent"


        MDTextFieldTrailingIcon:
            icon: "calendar"

<GetTimeDelta>:
    hours: int(str(hours.text)) if hours.text !='' else 0
    minutes: int(str(minutes.text)) if minutes.text !='' else 0
    MDBoxLayout:
        orientation: 'horizontal'
        MDTextField:
            input_type: 'number'
            input_filter: 'int'
            id:hours
            text:"0"
            MDTextFieldHelperText: 
                text:"Hours"
        MDTextField:
            input_type: 'number'
            input_filter: 'int'
            id:minutes
            text:"0"
            MDTextFieldHelperText: 
                text:"Minutes"


<LabelSlider>:
    value: slider.value
    MDBoxLayout:
        orientation: 'horizontal'
        MDLabel:
            text: self.parent.parent.title
            halign: "right"
        MDSlider:
            id: slider   
            step:1
            value:5
            max:10
            min:0
            MDSliderHandle
        MDLabel:
            text: f"{int(slider.value)}/10"



<NewTask>:
    Screen:
        MDBoxLayout:
            MDTextField:
                id: name
                MDTextFieldLeadingIcon:
                    icon: "checkbox-blank-circle-outline"
                MDTextFieldHintText: 
                    text: "Name"
            MDTextField:
                id: desc
                MDTextFieldHintText: 
                    text: "Description"
                MDTextFieldHelperText:
                    text: "Optional"





<Intro_Q>:
    Screen:
        BoxLayout:
            orientation: 'vertical'
            MDLabel:
                id: welcome_msg
                text: "Welcome back!"
            LabelSlider:
                id:energy
                title: 'Energy:'
            MDLabel:
                text: "How much time do you have?"
            GetTimeDelta:
                id:time
            MDButton:
                id:submit
                on_release: 
                    root.submit()
                MDButtonIcon: 
                    icon: "check-circle"

<taskCheck>:
    MDBoxLayout:
        height:200
        width:500
        orientation: 'horizontal'
        MDCheckbox:
            on_active: 
                app.complete_task()
        MDBoxLayout:
            spacing:0
            orientation: 'vertical'
            height:self.minimum_height
            MDLabel:
                height:50
                id:taskname
                text: root.name
                font_style:"Headline"
            MDLabel:
                height:40
                id:taskdesc
                text: root.desc
                       
<Home>:
    Screen:
        MDAnchorLayout:
            anchor_x: 'right'
            anchor_y: 'top'
            MDLabel:
                id:pointcount
                text: f"{self.parent.parent.parent.points} Points"
                pos_hint: {'x':1,'y':1}
                size_hint: (None,None)
        MDAnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'
            MDBoxLayout:
                id:tasklist
                orientation: 'vertical'
                adaptive_height:False
        MDNavigationBar:
            MDNavigationItem:
                id: addtask
                on_release: root.manager.current = 'AddTask'
                MDNavigationItemIcon:
                    icon: "plus-circle"
            MDNavigationItem:
                id:searchquery
                on_release: root.manager.current = 'SearchQuery'
                MDNavigationItemIcon:
                    icon: "magnify"

                

        
