#UI elements
MDScreen:
    md_bg_color: self.theme_cls.backgroundColor
    MDBoxLayout:
        orientation: 'vertical'
        size: root.width, root.height
        TimePicker
            #pos_hint:{"center_x":.8, "center_y":.9}
        DatePicker
        LabelSlider:
            title: "Energy"
            #pos_hint: {"center_x":.5, "center_y":.2}

<TimePicker>:
    MDButton:
        id: add_deadline
        style: "elevated"
        on_release: self.parent.show_time_picker(0,0)
        #on_cancel: self.dismiss()
       
        MDButtonIcon:
            icon: "plus"

        MDButtonText:
            text: "Add deadline..."
            halign: "center"

<DatePicker>:
    #pos_hint: {'center_x': .5, 'center_y': 1}
    #size_hint_x: .5
    MDTextField:
        id: field
        mode: "outlined"
        
        on_focus: self.parent.show_date_picker(self.focus, mydate)

        MDTextFieldHintText:
            id:mydate
            #text: self.set_text_full_date()

        MDTextFieldHelperText:
            text: "MM/DD/YYYY"
            mode: "persistent"

        MDTextFieldTrailingIcon:
            icon: "calendar"

<LabelSlider>:
    MDBoxLayout:
        orientation: 'horizontal'
        MDLabel:
            text: self.parent.parent.title
            halign: "right"
        MDSlider:
            id: slider    
            step:1
            value:5
            max:10
            min:0
            MDSliderHandle
        MDLabel:
            text: f"{int(slider.value)}/10"


<NewTask>:
    MDScreen:
        MDBoxLayout:
            MDTextField:
                id: name
                MDTextFieldLeadingIcon:
                    icon: "checkbox-blank-circle-outline"
                MDTextFieldHintText: 
                    text: "Name"
            MDTextField:
                id: desc
                MDTextFieldHintText: 
                    text: "Description"
                MDTextFieldHelperText:
                    text: "Optional"




<Intro_Questionnaire>:
    MDScreen:
        BoxLayout:
            orientation: 'vertical'
            MDLabel:
                id: welcome_msg
                text: "Welcome back!"
            LabelSlider:
                id:energy
                text: 'Energy:'
            MDLabel:
                text: "How much time do you have?"
        
